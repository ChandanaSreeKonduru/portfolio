/* ===== EXPERIENCE PAGE - EXACT RHODE MINIMALISM ===== */

/* Detailed Experience Timeline */
.experience-timeline {
    padding: var(--space-xl) 0;
    background: var(--bg-primary);
}

.timeline {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
}

/* Timeline line - ultra minimal */
.timeline::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 20px;
    width: 1px; /* Thinner line */
    background: var(--text-secondary);
}

.timeline-item {
    position: relative;
    margin-bottom: var(--space-xl);
    padding-left: 60px;
}

.timeline-marker {
    position: absolute;
    left: 12px;
    top: 8px;
    width: 16px;
    height: 16px;
    background: var(--bg-card);
    border: 1px solid var(--accent-primary); /* Simple border */
    border-radius: 0; /* Sharp corners */
    z-index: 2;
}

.marker-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-primary);
    border-radius: 0; /* Sharp dot */
    margin: 3px;
}

/* Current position marker */
.timeline-item.current .timeline-marker {
    background: var(--accent-primary);
}

.timeline-item.current .marker-dot {
    background: white;
    width: 10px;
    height: 10px;
    margin: 2px;
}

.timeline-header {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
    align-items: center;
}

.timeline-date {
    color: var(--text-secondary);
    font-size: 0.875rem;
    font-weight: 400;
}

.timeline-title {
    font-size: 1.25rem;
    margin-bottom: var(--space-xs);
    color: var(--text-primary);
    font-weight: 400;
}

.timeline-company {
    font-size: 1.125rem;
    color: var(--accent-primary);
    margin-bottom: var(--space-xs);
    font-weight: 400;
}

.timeline-location {
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin-bottom: var(--space-sm);
}

.timeline-description {
    color: var(--text-secondary);
    line-height: 1.7;
}

.achievement-list {
    list-style: none;
    margin: 0;
    padding: 0;
}

.achievement-list li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: var(--space-xs);
    line-height: 1.6;
    color: var(--text-primary);
}

.achievement-list li::before {
    content: "▶";
    color: var(--accent-primary);
    position: absolute;
    left: 0;
    font-weight: bold;
}

.highlight-metric {
    color: var(--accent-primary);
    font-weight: 400;
}

/* Global Journey Map Section */
.journey-map {
    padding: var(--space-xl) 0;
    background: var(--bg-card);
    border-top: var(--border-light);
}

.section-divider {
    width: 60px;
    height: 1px;
    background: var(--border-light);
    margin: var(--space-lg) auto;
    border: none;
}

.map-container {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--space-xl);
    align-items: start;
}

.world-map {
    background: var(--bg-primary);
    border-radius: 0; /* Sharp corners */
    padding: var(--space-lg);
    border: var(--border-light);
}

.map-svg {
    width: 100%;
    height: auto;
    display: block;
}

.location-dot {
    transition: none; /* No transitions */
}

.location-dot:hover {
    transform: none;
    filter: none;
}

.location-legend {
    background: var(--bg-primary);
    border-radius: 0; /* Sharp corners */
    padding: var(--space-lg);
    border: var(--border-light);
}

.location-legend h3 {
    color: var(--text-primary);
    margin-bottom: var(--space-md);
    font-size: 1.25rem;
    font-weight: 400;
}

.legend-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
}

.legend-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
}

.legend-color {
    width: 16px;
    height: 16px;
    border-radius: 0; /* Sharp legend dots */
    flex-shrink: 0;
}

.legend-color.asia { background: #67645e; }
.legend-color.europe { background: #67645e; }
.legend-color.north-america { background: #67645e; }

.legend-details {
    display: flex;
    flex-direction: column;
}

.legend-details .city {
    color: var(--text-primary);
    font-weight: 400;
    font-size: 0.875rem;
}

.legend-details .years {
    color: var(--text-secondary);
    font-size: 0.75rem;
}

/* Responsive Design for Experience Page */
@media (max-width: 1024px) {
    .map-container {
        grid-template-columns: 1fr;
        gap: var(--space-lg);
    }
    
    .world-map {
        padding: var(--space-md);
    }
}

@media (max-width: 768px) {
    .timeline::before {
        left: 15px;
    }
    
    .timeline-item {
        padding-left: 45px;
    }
    
    .timeline-marker {
        left: 7px;
        top: 6px;
    }
    
    .timeline-title {
        font-size: 1.125rem;
    }
    
    .timeline-company {
        font-size: 1rem;
    }
    
    .achievement-list li {
        font-size: 0.875rem;
    }
    
    .map-svg {
        height: 250px;
    }
    
    .location-legend {
        padding: var(--space-md);
    }
}

@media (max-width: 480px) {
    .timeline-header {
        flex-direction: column;
        align-items: flex-start;
    }
    
    .timeline-date {
        font-size: 0.75rem;
    }
    
    .map-container {
        gap: var(--space-md);
    }
    
    .world-map,
    .location-legend {
        padding: var(--space-sm);
    }
}